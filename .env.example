# ─── Required ─────────────────────────────────────────────────────────────
# At least one LLM API key (Gemini free tier works)
GEMINI_API_KEY=                  # https://aistudio.google.com/apikey
# Optional secondary providers
ANTHROPIC_API_KEY=               # https://console.anthropic.com/
OPENAI_API_KEY=                  # https://platform.openai.com/api-keys

# Internal RPC token — protects POST /memory/write etc.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
NOVA_INTERNAL_TOKEN=replace-with-random-hex-string

# ─── Server ───────────────────────────────────────────────────────────────
NOVA_KERNEL_ROOT=                # absolute path to this repo (auto-detected if empty)
NOVA_KERNEL_PORT=3700

# ─── Optional integrations ────────────────────────────────────────────────
# Antigravity ag-bridge (free Claude/Gemini routing if you run AG IDE locally)
# Listen URL is fixed at http://127.0.0.1:11435 — no setting needed; just install
# the marcodiniz.ag-local-bridge extension in Antigravity IDE.

# Notification channels (pick one — see kernel/notify/)
LARK_WEBHOOK=
WECHAT_WORK_WEBHOOK=
DINGTALK_WEBHOOK=

# ─── Tuning (advanced) ────────────────────────────────────────────────────
NOVA_SELF_MAINTENANCE=on         # off to disable cron jobs
NOVA_MEMORY_AUTO_SYNC=on         # off to disable 4-way projection
NOVA_INTENT_LLM_FALLBACK=on      # off if you don't want LLM-based intent classify
KB_REFINER_MODEL=                # override KB intel refiner model (default: antigravity-claude-sonnet-4-6)

# ─── Sandbox / dev ────────────────────────────────────────────────────────
# NOVA_SHADOW_PORT=3701          # optional Anthropic-proxy sniffer
# NOVA_SNIFFER_FULL=0            # 1 to log full request/response bodies
